# AEGIS runs fully KEY-FREE by default. Everything below is OPTIONAL.
# Copy this file to `.env.local` and fill in a value ONLY to enable that layer.

# --- Optional layers (off unless a key is present) ---

# AIS ship tracking. Free key from https://aisstream.io (GitHub sign-in).
# AISSTREAM_API_KEY=

# High-resolution wildfire hotspots (NASA FIRMS). Free MAP_KEY from
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
# FIRMS_MAP_KEY=

# Global public webcams (Windy). Free key from https://api.windy.com/keys
# (Public-camera layer works WITHOUT this via TfL London traffic cams.)
# WINDY_WEBCAMS_KEY=

# Internet outages (Cloudflare Radar). Free API token from your Cloudflare dashboard.
# CLOUDFLARE_API_TOKEN=

# Air quality (OpenAQ). Free key from https://explore.openaq.org
# OPENAQ_API_KEY=

# --- AI situation briefing (optional, local & private) ---
# Install Ollama (https://ollama.com) and `ollama run llama3.2` to enable.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Optional overrides ---

# Swap the basemap style if CARTO ever rate-limits. Any MapLibre style URL works.
# NEXT_PUBLIC_BASEMAP_STYLE=https://tiles.openfreemap.org/styles/dark

# Identify AEGIS to upstream APIs (CelesTrak/USGS ask clients to identify themselves).
# AEGIS_USER_AGENT=AEGIS/1.0 (+https://github.com/your/repo)
